# ──────────────────────────────────────────────
# Inventory Optimizer — Frontend Environment
# Copy to .env (dev) or .env.production (prod)
# ──────────────────────────────────────────────

# ── Clerk Auth ────────────────────────────────
# Required — get from https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend API ───────────────────────────────
# Dev:  leave empty → Vite proxy → localhost:4000
# Prod: set to your deployed API URL
VITE_API_URL=

# ── Vite Dev Proxy ────────────────────────────
# Override if your backend runs on a different port
# VITE_DEV_BACKEND=http://localhost:4000
